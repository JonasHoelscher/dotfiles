general {
    colors = true
    interval = 5
}

order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "tztime local"

wireless _first_ {
    format_up = "WLAN: (%quality at %essid) %ip"
    format_down = "WLAN: down"
}

ethernet _first_ {
    format_up = "ETH: %ip (%speed)"
    format_down = "ETH: down"
}

battery all {
    # Zeigt Kapazität und verbleibende Laufzeit an
    format = "%status %percentage %remaining"
}

tztime local {
    format = "%Y-%m-%d %H:%M:%S"
}
